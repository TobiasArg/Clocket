{
    "name": "clocket-backend",
    "version": "0.1.0",
    "private": true,
    "scripts": {
        "dev": "prisma generate && next dev -p 3001",
        "dev:docker": "prisma generate && next dev -H 0.0.0.0 -p 3001",
        "build": "prisma generate && next build",
        "start": "next start -p 3001",
        "test": "prisma generate && vitest run",
        "test:db": "RUN_DB_TESTS=1 vitest run src/persistence",
        "typecheck": "prisma generate && tsc --noEmit",
        "prisma:generate": "prisma generate",
        "prisma:validate": "prisma validate",
        "prisma:migrate:dev": "prisma migrate dev",
        "prisma:studio": "prisma studio"
    },
    "dependencies": {
        "@prisma/adapter-pg": "^7.8.0",
        "@prisma/client": "^7.8.0",
        "axios": "^1.13.2",
        "dotenv": "^17.4.2",
        "next": "^14.0.0",
        "react": "^18.2.0",
        "react-dom": "^18.2.0"
    },
    "devDependencies": {
        "@types/node": "^22.19.19",
        "@types/react": "^18.3.27",
        "@types/react-dom": "^18.3.7",
        "prisma": "^7.8.0",
        "typescript": "^5.9.3",
        "vitest": "^4.0.18"
    }
}
